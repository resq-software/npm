{
	"$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"css": {
		"parser": {
			"allowWrongLineComments": true,
			"cssModules": false
		}
	},
	"files": {
		"ignoreUnknown": true,
		"includes": ["**", "!src/styles/globals.css"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"trailingCommas": "all"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"a11y": {
				"noRedundantRoles": "off",
				"useAriaPropsForRole": "off",
				"useButtonType": "off",
				"useFocusableInteractive": "off",
				"useKeyWithClickEvents": "off",
				"useSemanticElements": "off"
			},
			"correctness": {
				"noUnusedVariables": "warn",
				"useExhaustiveDependencies": "off"
			},
			"security": {
				"noDangerouslySetInnerHtml": "off"
			},
			"style": {
				"noNonNullAssertion": "off"
			},
			"suspicious": {
				"noArrayIndexKey": "off",
				"noConsole": "off",
				"noDocumentCookie": "off",
				"noShadowRestrictedNames": "off",
				"useIterableCallbackReturn": "off"
			}
		}
	},
	"vcs": {
		"clientKind": "git",
		"enabled": true,
		"useIgnoreFile": true
	}
}
