{
  "name": "@resq-sw/helpers",
  "version": "0.1.1",
  "description": "Functional utilities, type guards, result types, performance measurement, and async task execution",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    },
    "./formatting": {
      "types": "./lib/formatting/index.d.ts",
      "import": "./lib/formatting/index.js",
      "default": "./lib/formatting/index.js"
    },
    "./browser": {
      "types": "./lib/browser/index.d.ts",
      "import": "./lib/browser/index.js",
      "default": "./lib/browser/index.js"
    }
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run"
  },
  "dependencies": {
    "@resq-sw/logger": "workspace:*",
    "tinyqueue": "^3.0.0"
  },
  "devDependencies": {
    "jsdom": "^29.0.2",
    "tsdown": "^0.21.7",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/resq-software/npm.git",
    "directory": "packages/helpers"
  },
  "keywords": [
    "helpers",
    "utilities",
    "result-type",
    "type-guards",
    "task-queue"
  ],
  "engines": {
    "node": ">=20.19.0"
  }
}
