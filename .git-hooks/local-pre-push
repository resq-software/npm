#!/usr/bin/env bash
# Repo-specific pre-push — runs alongside the canonical ResQ pre-push hook.
# Fails fast if bunx isn't available so the lint gate can't be silently skipped.
set -euo pipefail

if ! command -v bunx >/dev/null 2>&1; then
    echo "❌ bunx not found; cannot run required Biome lint gate." >&2
    echo "   Install bun: https://bun.sh" >&2
    exit 1
fi

echo "  TS/JS: bunx biome check"
if ! bunx biome check --no-errors-on-unmatched .; then
    echo "❌ Biome check failed. Run: bunx biome check --apply ." >&2
    exit 1
fi
