#!/usr/bin/env bash
# Notify (do not auto-mutate) when bun lockfile changes after a merge.
# Set BUN_INSTALL_AFTER_MERGE=1 to auto-run `bun install --frozen-lockfile`.
# Set SKIP_BUN_INSTALL=1 to silence everything.
set -euo pipefail

[ -n "${SKIP_BUN_INSTALL:-}" ] && exit 0

CHANGED=$(git diff-tree -r --name-only --no-commit-id ORIG_HEAD HEAD 2>/dev/null || true)
case "$CHANGED" in
    *bun.lock*)
        echo "📦 bun lockfile changed after merge."
        if [ "${BUN_INSTALL_AFTER_MERGE:-0}" = "1" ] && command -v bun >/dev/null 2>&1; then
            echo "   Running bun install --frozen-lockfile (BUN_INSTALL_AFTER_MERGE=1)..."
            bun install --frozen-lockfile
        else
            echo "   Run 'bun install' to sync; set BUN_INSTALL_AFTER_MERGE=1 to auto-run."
        fi
        ;;
esac
