#!/usr/bin/env bash
# Automatic bun install when bun.lockb changes on branch switch.
# Override: export SKIP_BUN_INSTALL=1
set -euo pipefail

PREV_HEAD="${1:-}"
NEW_HEAD="${2:-}"
IS_BRANCH_CHECKOUT="${3:-}"

[ "$IS_BRANCH_CHECKOUT" = "1" ] || exit 0
[ "$PREV_HEAD" = "$NEW_HEAD" ] && exit 0

CHANGED=$(git diff --name-only "$PREV_HEAD" "$NEW_HEAD" 2>/dev/null || true)
if echo "$CHANGED" | grep -q "^bun\.lockb\?$"; then
    if [ -n "${SKIP_BUN_INSTALL:-}" ]; then
        echo "📦 bun lockfile changed — skipping install (SKIP_BUN_INSTALL set)"
    elif command -v bun >/dev/null 2>&1; then
        echo "📦 bun lockfile changed — running bun install..."
        bun install --frozen-lockfile || bun install
    fi
fi
